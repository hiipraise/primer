# ─── Primer — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Required variables will cause the app to fail at startup if missing.

# ─── Supabase ───────────────────────────────────────────────────────
# Your Supabase project URL and anon/public key.
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Groq API ───────────────────────────────────────────────────────
# API key for Groq's Llama 3.3 70B model (used for recommendations).
# Get one at: https://console.groq.com/keys
# Free tier: 30 req/min on Llama 3.3 70B — enough for development.
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Site URL (optional) ────────────────────────────────────────────
# Your app's public URL. Used for OAuth redirects.
# Defaults to http://localhost:3000 in development.
# In production, set this to your Vercel deployment URL or custom domain.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
